{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentforge.local/schemas/review-result.schema.json",
  "title": "Agent Forge Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "work_order_ref",
    "candidate_ref",
    "reviewer_role",
    "review_scope",
    "findings",
    "outcome",
    "evidence_checked",
    "limitations",
    "reviewed_at"
  ],
  "properties": {
    "schema_version": {"const": "agentforge.review_result/v1"},
    "review_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_.-]{2,127}$"},
    "work_order_ref": {"type": "string", "minLength": 1},
    "candidate_ref": {"type": "string", "minLength": 1},
    "reviewer_role": {"type": "string", "minLength": 1},
    "reviewer_identity": {"type": "string"},
    "independent": {"type": "boolean"},
    "conflict_of_interest": {"type": "string"},
    "review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_ids", "focus", "excluded"],
      "properties": {
        "requirement_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "focus": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "excluded": {"type": "array", "items": {"type": "string"}},
        "files_or_components": {"type": "array", "items": {"type": "string"}}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_id", "severity", "category", "description", "disposition", "owner"],
        "properties": {
          "finding_id": {"type": "string"},
          "severity": {"enum": ["blocker", "critical", "major", "minor", "advisory"]},
          "category": {"enum": ["scope", "product", "architecture", "security", "data", "runtime", "api", "frontend", "platform", "evaluation", "operations", "evidence", "other"]},
          "description": {"type": "string", "minLength": 1},
          "reference": {"type": "string"},
          "disposition": {"enum": ["open", "resolved", "accepted_risk", "deferred", "not_applicable"]},
          "owner": {"type": "string", "minLength": 1},
          "required_action": {"type": "string"},
          "resolution_evidence_ref": {"type": "string"}
        }
      }
    },
    "outcome": {
      "enum": ["accepted", "changes_required", "hold", "rejected", "advisory"]
    },
    "evidence_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reference", "result"],
        "properties": {
          "reference": {"type": "string"},
          "result": {"enum": ["sufficient", "insufficient", "not_applicable"]},
          "notes": {"type": "string"}
        }
      }
    },
    "limitations": {"type": "array", "items": {"type": "string"}},
    "required_rework": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "owner", "blocking"],
        "properties": {
          "action": {"type": "string"},
          "owner": {"type": "string"},
          "blocking": {"type": "boolean"},
          "verification": {"type": "string"}
        }
      }
    },
    "reviewed_at": {"type": "string", "format": "date-time"},
    "supersedes": {"type": "string"}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "findings": {
            "contains": {
              "properties": {
                "severity": {"enum": ["blocker", "critical"]},
                "disposition": {"const": "open"}
              },
              "required": ["severity", "disposition"]
            }
          }
        }
      },
      "then": {
        "properties": {
          "outcome": {"enum": ["changes_required", "hold", "rejected"]}
        }
      }
    }
  ]
}
