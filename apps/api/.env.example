# ── App ──────────────────────────────────────────────────────────────
AGENT_FORGE_APP_NAME=Agent Forge API                 # display name for the API
AGENT_FORGE_ENVIRONMENT=local                         # deployment environment label (local | staging | prod, informational)
AGENT_FORGE_DATABASE_URL=postgresql+psycopg://agentforge:agentforge@localhost:5432/agentforge  # SQLAlchemy connection string
AGENT_FORGE_READINESS_CHECK_DATABASE=false            # if true, /readiness probes the DB connection
AGENT_FORGE_CORS_ORIGINS=["http://localhost:3000"]    # JSON array of allowed browser origins

# ── Language model (LLM gateway) ────────────────────────────────────
AGENT_FORGE_LLM_BASE_URL=                             # OpenAI-compatible base URL incl. version prefix, e.g. http://host:11434/v1; empty = LLM disabled (fallback text only)
AGENT_FORGE_LLM_MODEL=qwen3:8b                        # model name sent in the chat/completions request
AGENT_FORGE_LLM_TIMEOUT_SECONDS=30.0                  # per-request HTTP timeout for generation calls
AGENT_FORGE_LLM_TEMPERATURE=0.2                       # default sampling temperature (clamped to a conservative RAG range at call time)
AGENT_FORGE_LLM_TOP_P=                                # optional nucleus-sampling top_p; empty = omitted from the request
AGENT_FORGE_LLM_API_KEY=                              # optional bearer token for the LLM gateway; empty = no Authorization header sent (in-house/prod gateways that require auth need this set)

# ── Embedding gateway ────────────────────────────────────────────────
AGENT_FORGE_EMBEDDING_BASE_URL=                       # OpenAI-compatible embeddings base URL incl. version prefix; empty = embedding disabled
AGENT_FORGE_EMBEDDING_MODEL=bge-m3                    # model name sent in the embeddings request
AGENT_FORGE_EMBEDDING_DIM=1024                        # expected embedding vector dimensionality (must match the vector store collection)
AGENT_FORGE_EMBEDDING_TIMEOUT_SECONDS=30.0            # per-request HTTP timeout for embedding calls
AGENT_FORGE_EMBEDDING_API_KEY=                        # optional bearer token for the embedding gateway; empty = no Authorization header sent

# ── Vector store ─────────────────────────────────────────────────────
AGENT_FORGE_QDRANT_URL=http://localhost:6333          # Qdrant endpoint used when VECTOR_BACKEND=qdrant
AGENT_FORGE_VECTOR_BACKEND=fake                       # "fake" (in-memory, tests/dev) | "qdrant" (real vector search)

# ── Retrieval gating ─────────────────────────────────────────────────
AGENT_FORGE_RETRIEVAL_MIN_SCORE=0.0                   # drop retrieval hits below this similarity score (relevance gate)
AGENT_FORGE_ANSWER_MIN_SCORE=0.0                      # refuse to answer if the top hit scores below this (answer-confidence gate, separate from retrieval gate)
AGENT_FORGE_GROUNDING_MIN=0.0                         # refuse answers grounded below this score (injection/hallucination guard)

# ── Chunking ─────────────────────────────────────────────────────────
AGENT_FORGE_CHUNK_TARGET_TOKENS=320                   # heading-bounded chunk size (eojeol proxy; ~650 subword tokens)
AGENT_FORGE_CHUNK_OVERLAP_TOKENS=50                   # sliding-window overlap between chunks (eojeol proxy; ~100 subword tokens)

# ── PII masking ──────────────────────────────────────────────────────
AGENT_FORGE_PII_MASKING_ENABLED=false                 # regex-redact PII in answer + returned chunk content (default off)

# ── Object storage (AF-009: original upload bytes) ──────────────────
AGENT_FORGE_OBJECT_STORE_BACKEND=none                 # "none" (disabled) | "memory" (dev/test) | "minio" (S3-compatible, persists originals)
AGENT_FORGE_OBJECT_STORE_ENDPOINT=                    # MinIO/S3 endpoint host:port; required when backend=minio
AGENT_FORGE_OBJECT_STORE_ACCESS_KEY=agentforge        # MinIO/S3 access key
AGENT_FORGE_OBJECT_STORE_SECRET_KEY=agentforge-local  # MinIO/S3 secret key
AGENT_FORGE_OBJECT_STORE_BUCKET=agentforge            # bucket name for uploaded originals
AGENT_FORGE_OBJECT_STORE_SECURE=false                 # use TLS (https) when talking to the object store endpoint

# ── Reranking ────────────────────────────────────────────────────────
AGENT_FORGE_RERANK_BACKEND=none                       # "none" (order-preserving no-op) | future: vllm cross-encoder — see docs/research-reranking-options.md

# ── Answerability judge ──────────────────────────────────────────────
AGENT_FORGE_JUDGE_BACKEND=none                        # "none" (always answerable) | "llm" (LLM answerability judge via the LLM gateway; refusal discipline)
